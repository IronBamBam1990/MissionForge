  "trigger_patterns": {
    "area_cleared": {
      "description": "Trigger when no OPFOR in area",
      "activation": "EAST",
      "activation_type": "NOT PRESENT",
      "condition": "this",
      "on_activation": "[taskID, 'SUCCEEDED'] call BIS_fnc_taskSetState;"
    },
    "unit_killed": {
      "description": "Trigger when specific unit is killed",
      "condition": "!alive targetUnit",
      "on_activation": "[taskID, 'SUCCEEDED'] call BIS_fnc_taskSetState;"
    },
    "hostage_killed": {
      "description": "Trigger when hostage dies - mission fail",
      "condition": "!alive hostageUnit",
      "on_activation": "['Lose', false] call BIS_fnc_endMission;"
    },
    "all_objectives_complete": {
      "description": "Win condition - all tasks succeeded",
      "condition": "['task1','task2'] findIf {!(_x call BIS_fnc_taskCompleted)} == -1",
      "on_activation": "['end1', true] call BIS_fnc_endMission;"
    },
    "all_players_dead": {
      "description": "Lose condition",
      "condition": "{alive _x} count allPlayers == 0",
      "on_activation": "['Lose', false] call BIS_fnc_endMission;"
    },
    "convoy_reached_destination": {
      "description": "Convoy escort win condition",
      "activation": "WEST",
      "activation_type": "PRESENT",
      "condition": "this && alive convoyVehicle"
    },
    "timer_expired": {
      "description": "Time limit trigger",
      "condition": "time > timeLimit",
      "on_activation": "['end1', true] call BIS_fnc_endMission;"
    }
  },
  "mission_patterns": {
    "hostage_rescue": {
      "description": "Rescue hostages from OPFOR-held building",
      "required_elements": {
        "hostages": "Civilian units placed inside building, setCaptive true",
        "guards": "OPFOR garrison in same building, AWARE/RED",
        "entry_points": "Multiple approach vectors",
        "extraction": "LZ marker for helicopter extraction",
        "win_condition": "All hostages alive + extracted to LZ",
        "lose_conditions": [
          "Hostage killed",
          "All players dead",
          "Time expired"
        ]
      },
      "sqf_setup": {
        "hostage_init": "this setCaptive true; this disableAI 'MOVE'; this setVariable ['isHostage', true, true];",
        "guard_behavior": "garrison in buildings, AWARE, RED combat mode",
        "win_trigger": "({_x getVariable ['isHostage',false]} count (allUnits select {alive _x && _x distance lzPos < 50})) >= hostageCount",
        "lose_trigger": "({!alive _x} count hostages) > 0"
      }
    },
    "assault_raid": {
      "description": "Attack and clear enemy positions",
      "required_elements": {
        "objectives": "Multiple clear zones with OPFOR",
        "approach_route": "Waypoints from start to first objective",
        "support_positions": "SBF markers for fire support",
        "win_condition": "All objectives cleared (no OPFOR in zone)",
        "lose_conditions": [
          "All players dead"
        ]
      },
      "sqf_setup": {
        "clear_trigger_per_zone": "EAST NOT PRESENT in trigger area = objective complete",
        "all_clear": "All zone triggers activated = mission complete"
      }
    },
    "convoy_ambush": {
      "description": "Ambush enemy convoy on route",
      "required_elements": {
        "convoy_vehicles": "Multiple vehicles with waypoint route",
        "convoy_route": "Series of MOVE waypoints along road",
        "ambush_position": "Player start near kill zone",
        "win_condition": "All convoy vehicles destroyed",
        "lose_conditions": [
          "Convoy escapes (reaches final WP)",
          "All players dead"
        ]
      },
      "sqf_setup": {
        "convoy_waypoints": "MOVE waypoints along road, SAFE behavior, LIMITED speed",
        "escape_trigger": "Convoy vehicle reaches final waypoint",
        "destroy_trigger": "All convoy vehicles !alive"
      }
    },
    "convoy_escort": {
      "description": "Escort friendly convoy to destination",
      "required_elements": {
        "convoy_vehicles": "Friendly vehicles with waypoint route",
        "enemy_ambush_positions": "OPFOR groups along route",
        "win_condition": "Convoy reaches destination alive",
        "lose_conditions": [
          "Convoy destroyed",
          "All players dead"
        ]
      }
    },
    "defense": {
      "description": "Defend position against enemy waves",
      "required_elements": {
        "defense_position": "Fortified area with player start",
        "enemy_waves": "Multiple OPFOR groups spawning at intervals",
        "win_condition": "Survive all waves / time limit",
        "lose_conditions": [
          "All defenders dead",
          "Position overrun"
        ]
      },
      "sqf_setup": {
        "wave_spawn": "sleep between waves, createGroup+createUnit, SAD waypoint toward defense",
        "wave_trigger": "Previous wave mostly dead = spawn next wave"
      }
    },
    "search_and_rescue": {
      "description": "Find and extract VIP/pilot",
      "required_elements": {
        "vip": "Friendly or civilian unit at crash/hidden location",
        "search_area": "Area marker for search zone",
        "enemy_patrols": "OPFOR patrols in search area",
        "extraction_lz": "Helicopter landing zone",
        "win_condition": "VIP alive at extraction LZ",
        "lose_conditions": [
          "VIP killed",
          "All players dead"
        ]
      }
    },
    "recon": {
      "description": "Infiltrate, observe, report, exfiltrate",
      "required_elements": {
        "observation_targets": "Markers at locations to observe",
